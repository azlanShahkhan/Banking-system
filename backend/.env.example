# Environment variables for Banking System
# Copy this file to .env and fill in the values

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DB_PATH=./banking.db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRY=24h

# Password Configuration
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=10

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Configuration
API_TIMEOUT=30000
